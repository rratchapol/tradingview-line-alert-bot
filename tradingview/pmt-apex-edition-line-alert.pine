//@version=5
strategy("THE GREATEST BOT EVER MADE - PMT APEX EDITION + LINE", overlay=true, initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1)

// ==========================================
// 1. RISK, PMT & LINE SETUP
// ==========================================
slTicks = input.int(400, title="Stop Loss (Ticks)")
trailActiv = input.int(100, title="Trail Activation (Ticks)")
trailOffset = input.int(50, title="Trail Offset (Ticks)")

pmtLongMsg = input.string('{"action": "buy", "symbol": "MNQM2026", "quantity": 2}', title="PMT Long JSON")
pmtShortMsg = input.string('{"action": "sell", "symbol": "MNQM2026", "quantity": 2}', title="PMT Short JSON")
pmtExitMsg = input.string('{"action": "exit", "symbol": "MNQM2026"}', title="PMT Exit JSON")

alertSecret = input.string("change_this_to_match_ALERT_WEBHOOK_SECRET", title="LINE Webhook Secret")

// ==========================================
// 2. INDICATORS
// ==========================================
rsiVal = ta.rsi(close, 14)
[macdLine, signalLine, _] = ta.macd(close, 12, 26, 9)
[plusDI, minusDI, adxVal] = ta.dmi(14, 14)
atrVal = ta.atr(14)
volSma = ta.sma(volume, 20)
highVolume = volume > volSma

// ==========================================
// 3. STRUCTURAL PATTERNS & VISUALS
// ==========================================
bullishFVG = low > high[2] and close[1] > open[1]
bearishFVG = high < low[2] and close[1] < open[1]

bgcolor(bullishFVG ? color.new(color.green, 85) : na, title="Bullish FVG")
bgcolor(bearishFVG ? color.new(color.red, 85) : na, title="Bearish FVG")

bullReversal = ta.crossover(macdLine, signalLine) and rsiVal < 40
bearReversal = ta.crossunder(macdLine, signalLine) and rsiVal > 60

bullFlag = close > ta.sma(close, 20) and highVolume and bullishFVG
bearFlag = close < ta.sma(close, 20) and highVolume and bearishFVG

// ==========================================
// 4. LINE ALERT MESSAGES
// ==========================================
longReason =
     bullishFVG ? "🟩 เจอ Bullish FVG" :
     bullReversal ? "🔄 MACD ตัดขึ้นและ RSI ต่ำกว่า 40 มีโอกาสกลับตัวขึ้น" :
     bullFlag ? "🚩 Bull Flag พร้อม Volume สูง" :
     "🟢 เงื่อนไข Long ของ APEX ผ่าน"

shortReason =
     bearishFVG ? "🟥 เจอ Bearish FVG" :
     bearReversal ? "🔄 MACD ตัดลงและ RSI สูงกว่า 60 มีโอกาสกลับตัวลง" :
     bearFlag ? "🚩 Bear Flag พร้อม Volume สูง" :
     "🔴 เงื่อนไข Short ของ APEX ผ่าน"

longRiskText = "🛑 ตัดขาดทุนเมื่อราคาสวนทาง " + str.tostring(slTicks) + " ticks"
shortRiskText = "🛑 ตัดขาดทุนเมื่อราคาสวนทาง " + str.tostring(slTicks) + " ticks"
takeProfitText = "🎯 ใช้ Trailing Stop: เริ่มล็อกกำไรเมื่อบวก " + str.tostring(trailActiv) + " ticks และตามราคาห่าง " + str.tostring(trailOffset) + " ticks"
riskPlanText = "Trailing Stop | SL " + str.tostring(slTicks) + " ticks | Trail +" + str.tostring(trailActiv) + " / Offset " + str.tostring(trailOffset)

lineLongMsg = '{"secret":"' + alertSecret + '","symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"{{time}}","timeframe":"' + timeframe.period + '","side":"🟢 LONG","setup":"PMT APEX EDITION","bias":"ฝั่ง Long","entry":"' + str.tostring(close) + '","sl":"' + longRiskText + '","tp":"' + takeProfitText + '","rr":"' + riskPlanText + '","reasons":["' + longReason + '","📊 Volume สูงกว่าค่าเฉลี่ย","💪 ADX มากกว่า 20 ตลาดมีแรงพอ"]}'

lineShortMsg = '{"secret":"' + alertSecret + '","symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"{{time}}","timeframe":"' + timeframe.period + '","side":"🔴 SHORT","setup":"PMT APEX EDITION","bias":"ฝั่ง Short","entry":"' + str.tostring(close) + '","sl":"' + shortRiskText + '","tp":"' + takeProfitText + '","rr":"' + riskPlanText + '","reasons":["' + shortReason + '","📊 Volume สูงกว่าค่าเฉลี่ย","💪 ADX มากกว่า 20 ตลาดมีแรงพอ"]}'

// ==========================================
// 5. EXECUTION
// ==========================================
longCond = (bullishFVG or bullReversal or bullFlag) and highVolume and adxVal > 20
if longCond and strategy.position_size == 0
    strategy.entry("APEX_LONG", strategy.long, alert_message=pmtLongMsg)
    alert(lineLongMsg, alert.freq_once_per_bar_close)

shortCond = (bearishFVG or bearReversal or bearFlag) and highVolume and adxVal > 20
if shortCond and strategy.position_size == 0
    strategy.entry("APEX_SHORT", strategy.short, alert_message=pmtShortMsg)
    alert(lineShortMsg, alert.freq_once_per_bar_close)

if strategy.position_size > 0
    strategy.exit("Exit Long", "APEX_LONG", loss=slTicks, trail_points=trailActiv, trail_offset=trailOffset, alert_message=pmtExitMsg)

if strategy.position_size < 0
    strategy.exit("Exit Short", "APEX_SHORT", loss=slTicks, trail_points=trailActiv, trail_offset=trailOffset, alert_message=pmtExitMsg)

// ==========================================
// 6. DASHBOARD
// ==========================================
var table stats = table.new(position.bottom_right, 2, 6, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)

if barstate.islast
    currentEntry = strategy.position_size != 0 ? strategy.opentrades.entry_price(strategy.opentrades - 1) : na
    table.cell(stats, 0, 0, "THE GREATEST BOT EVER MADE", text_color=color.white, text_size=size.normal)
    table.merge_cells(stats, 0, 0, 1, 0)
    table.cell(stats, 0, 1, "Entry Price:", text_color=color.gray, text_halign=text.align_left)
    table.cell(stats, 1, 1, not na(currentEntry) ? str.tostring(currentEntry) : "Awaiting Signal...", text_color=color.white, text_halign=text.align_right)
    table.cell(stats, 0, 2, "Risk Mgmt:", text_color=color.gray, text_halign=text.align_left)
    table.cell(stats, 1, 2, str.tostring(slTicks) + " Ticks SL", text_color=color.white, text_halign=text.align_right)
    table.cell(stats, 0, 3, "Take Profit:", text_color=color.gray, text_halign=text.align_left)
    table.cell(stats, 1, 3, "Auto Trail Active", text_color=color.white, text_halign=text.align_right)
    table.cell(stats, 0, 4, "RSI | ADX:", text_color=color.gray, text_halign=text.align_left)
    table.cell(stats, 1, 4, str.tostring(nz(rsiVal, 0), "#.##") + " | " + str.tostring(nz(adxVal, 0), "#.##"), text_color=color.white, text_halign=text.align_right)
    table.cell(stats, 0, 5, "MACD | ATR:", text_color=color.gray, text_halign=text.align_left)
    table.cell(stats, 1, 5, str.tostring(nz(macdLine, 0), "#.##") + " | " + str.tostring(nz(atrVal, 0), "#.##"), text_color=color.white, text_halign=text.align_right)
